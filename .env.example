# MySQL Connection
# Local dev: mysql://dandu:dandu123@127.0.0.1:3306/gandu
# Docker network: mysql://dandu:dandu123@mysql:3306/gandu
DATABASE_URL=mysql://dandu:dandu123@127.0.0.1:3306/gandu
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=gandu
DATABASE_USER=dandu
DATABASE_PASSWORD=dandu123
MYSQL_ROOT_PASSWORD=root

NODE_ENV=development

PORT=5000
BACKEND_PORT=5000
ENABLE_SWAGGER=true
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info

JWT_SECRET=a-string-secret-at-least-256-bits-long
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
RATE_LIMIT_ENABLED=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_CACHE_KEY_PREFIX=dandu

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@yourapp.com

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Linnworks Configuration
LINNWORKS_APPLICATION_ID=your-linnworks-application-id
LINNWORKS_APPLICATION_SECRET=your-linnworks-application-secret
LINNWORKS_INSTALLATION_TOKEN=your-linnworks-installation-token
LINNWORKS_AUTH_TOKEN=
LINNWORKS_INSTALLATION_ID=
LINNWORKS_SESSION_TOKEN=
LINNWORKS_API_SERVER=https://api.linnworks.net

# Optional Loki logging
LOKI_ENABLED=false
LOKI_URL=http://localhost:3100
